{
  "name": "Keepmarks",
  "short_name": "Keepmarks",
  "version": "0.1.0.0",
  "manifest_version": 3,
  "description": "A convenient interface to organize your Bookmarks.",
  "icons": {
    "128": "icons/icon_128.png",
    "48": "icons/icon_48.png",
    "32": "icons/icon_32.png",
    "16": "icons/icon_16.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "bookmarks",
    "favicon"
  ],
  "optional_host_permissions": [
    "file:///"
  ],
  "action": {
    "default_icon": {
      "128": "icons/icon_128.png",
      "48": "icons/icon_48.png",
      "32": "icons/icon_32.png",
      "16": "icons/icon_16.png"
    }
  }
}
